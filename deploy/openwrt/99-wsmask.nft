# wsmask — transparent TCP redirect to local wsmask-client
#
# Install on OpenWrt 22.03+ (fw4 / nftables):
#   1. Edit the three `define` lines below.
#   2. scp this file to the router:  /etc/nftables.d/99-wsmask.nft
#   3. fw4 restart
#   4. Verify:  nft list table ip wsmask

define WSMASK_PORT = 12345
define VPS_IP      = 203.0.113.1     # <<< CHANGE: your VPS public IP (or name it with a set below)
define LAN_IFACE   = "br-lan"        # <<< CHANGE if your LAN bridge is different (run: ip link)

table ip wsmask {
    # Private / reserved / multicast / documentation ranges we must NOT redirect
    set reserved {
        type ipv4_addr
        flags interval
        elements = {
            0.0.0.0/8,
            10.0.0.0/8,
            100.64.0.0/10,
            127.0.0.0/8,
            169.254.0.0/16,
            172.16.0.0/12,
            192.0.0.0/24,
            192.0.2.0/24,
            192.88.99.0/24,
            192.168.0.0/16,
            198.18.0.0/15,
            198.51.100.0/24,
            203.0.113.0/24,
            224.0.0.0/4,
            240.0.0.0/4,
            255.255.255.255/32
        }
    }

    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;

        # Only touch TCP packets that entered via the LAN bridge
        iifname != $LAN_IFACE return
        meta l4proto != tcp      return

        # Never redirect traffic destined to the VPS itself (loop prevention)
        ip daddr $VPS_IP return

        # Never redirect LAN-internal / reserved destinations
        ip daddr @reserved return

        # Everything else: transparent REDIRECT to wsmask-client
        redirect to :$WSMASK_PORT
    }
}
