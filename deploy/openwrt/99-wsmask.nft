# wsmask: transparent TCP redirect to local wsmask-client
#
# Install on OpenWrt 22.03+ (fw4 / nftables):
#   1. scp this file to the router as /etc/nftables.d/99-wsmask.nft
#   2. Edit the VPS IP below (search: CHANGE_ME_VPS_IP)
#   3. Verify your LAN bridge name with `ip link` and adjust "br-lan" if needed
#   4. fw4 restart
#   5. nft list table ip wsmask

table ip wsmask {
    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;

        # Only touch TCP entering via the LAN bridge
        iifname != "br-lan" return
        meta l4proto != tcp return

        # CHANGE_ME_VPS_IP: replace 203.0.113.1 with your VPS public IP
        # (prevents redirecting the tunnel's own traffic back into itself)
        ip daddr 203.0.113.1 return

        # Skip all LAN / reserved / multicast destinations
        ip daddr {
            0.0.0.0/8,
            10.0.0.0/8,
            100.64.0.0/10,
            127.0.0.0/8,
            169.254.0.0/16,
            172.16.0.0/12,
            192.0.0.0/24,
            192.0.2.0/24,
            192.88.99.0/24,
            192.168.0.0/16,
            198.18.0.0/15,
            198.51.100.0/24,
            203.0.113.0/24,
            224.0.0.0/4,
            240.0.0.0/4
        } return

        # Everything else: REDIRECT to wsmask-client
        redirect to :12345
    }
}
